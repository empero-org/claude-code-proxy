# ============================================================
# Claude Code Proxy v0.1 — Configuration
# ============================================================

# Required: API key for your OpenAI-compatible backend
OPENAI_API_KEY="your-api-key-here"

# Optional: Client authentication
# If set, clients must send this exact key to access the proxy
# ANTHROPIC_API_KEY="your-gating-key"

# Backend URL (default: https://api.openai.com/v1)
# OPENAI_BASE_URL="https://api.openai.com/v1"

# Azure OpenAI — uncomment to enable Azure mode
# AZURE_API_VERSION="2024-12-01-preview"

# ---- Model mapping ----
# Claude opus  → BIG_MODEL    (default: gpt-4o)
# Claude sonnet → MIDDLE_MODEL (default: same as BIG_MODEL)
# Claude haiku  → SMALL_MODEL  (default: gpt-4o-mini)
BIG_MODEL="gpt-4o"
# MIDDLE_MODEL="gpt-4o"
SMALL_MODEL="gpt-4o-mini"

# ---- Server ----
HOST="0.0.0.0"
PORT="8082"
LOG_LEVEL="INFO"

# ---- Limits ----
# Fallback max output tokens (used when backend doesn't report model limits)
# MAX_TOKENS_LIMIT="128000"
# Floor for max_tokens (extended thinking requires >= 1024)
# MIN_TOKENS_LIMIT="1024"
REQUEST_TIMEOUT="90"

# ---- Custom headers ----
# Inject extra headers into backend requests via CUSTOM_HEADER_* prefix
# CUSTOM_HEADER_X_API_KEY="your-api-key"
# CUSTOM_HEADER_AUTHORIZATION="Bearer your-token"

# ============================================================
# Provider examples (uncomment one block)
# ============================================================

# --- Azure OpenAI ---
# OPENAI_API_KEY="your-azure-key"
# OPENAI_BASE_URL="https://your-resource.openai.azure.com/openai/deployments/your-deployment"
# AZURE_API_VERSION="2024-12-01-preview"
# BIG_MODEL="gpt-4o"
# SMALL_MODEL="gpt-4o-mini"

# --- Ollama (local) ---
# OPENAI_API_KEY="dummy"
# OPENAI_BASE_URL="http://localhost:11434/v1"
# BIG_MODEL="llama3.1:70b"
# SMALL_MODEL="llama3.1:8b"

# --- DeepSeek ---
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.deepseek.com/v1"
# BIG_MODEL="deepseek-chat"
# SMALL_MODEL="deepseek-chat"
